{
  "name": "industrial-model",
  "version": "0.9.0",
  "description": "TypeScript SDK for querying Cognite Industrial Data Models with a type-safe, graph-aware API",
  "license": "MIT",
  "keywords": [
    "cognite",
    "industrial",
    "data-model",
    "cdf",
    "sdk",
    "typescript",
    "fdm",
    "flexible-data-models"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasrosaalves/industrial-model-ts.git"
  },
  "bugs": {
    "url": "https://github.com/lucasrosaalves/industrial-model-ts/issues"
  },
  "homepage": "https://github.com/lucasrosaalves/industrial-model-ts#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "bin": {
    "industrial-model": "./dist/cli/index.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cognite-core": {
      "import": {
        "types": "./dist/cognite-core/index.d.ts",
        "default": "./dist/cognite-core/index.js"
      },
      "require": {
        "types": "./dist/cognite-core/index.d.cts",
        "default": "./dist/cognite-core/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release:version": "changeset version",
    "release:publish": "changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.27.12",
    "@cognite/sdk": "^10.10.0",
    "@inquirer/prompts": "^8.4.3",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^3.1.3",
    "commander": "^14.0.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {
    "@cognite/sdk": "^10.10.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
